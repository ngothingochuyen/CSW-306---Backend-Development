@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Login - Library Chat</title>
    <style>
        body {
            font-family: 'Segoe UI', sans-serif;
            background-color: #FFF0F5;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            margin: 0;
        }
        .login-box {
            background: white;
            padding: 40px;
            border-radius: 16px;
            box-shadow: 0 4px 15px rgba(255, 182, 193, 0.4);
            border: 1px solid #FFD1DC;
            width: 300px;
            text-align: center;
        }
        h2 { color: #FF1493; margin-bottom: 20px; }
        input {
            width: 100%;
            padding: 12px;
            margin-bottom: 20px;
            border: 1px solid #FFB6C1;
            border-radius: 8px;
            box-sizing: border-box;
            background-color: #FFF5F7;
        }
        button {
            width: 100%;
            padding: 12px;
            background: #FF1493;
            color: white;
            border: none;
            border-radius: 8px;
            font-weight: bold;
            cursor: pointer;
        }
        button:hover { background: #C71585; }
    </style>
</head>
<body>
    <div class="login-box">
        <h2>Chat Login</h2>
        <form action="/Account/Login" method="post">
            <input type="text" name="username" placeholder="Enter your nickname..." required />
            <button type="submit">Sign In</button>
        </form>
    </div>
</body>
</html>